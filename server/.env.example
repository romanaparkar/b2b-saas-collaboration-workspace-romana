# ---------------------------------------------------------------------------
# Server environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values:
#
#   cp .env.example .env
#
# `.env` is git-ignored and must never be committed.
# ---------------------------------------------------------------------------

# Runtime environment: "development" | "production" | "test"
NODE_ENV=development

# Port the API server listens on.
PORT=5000

# Origin of the frontend client (used for CORS). Vite dev server default:
CLIENT_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# MongoDB Atlas connection string.
#
# Expected format:
#   mongodb+srv://<username>:<url-encoded-password>@<cluster-host>/<database-name>?retryWrites=true&w=majority&appName=<AppName>
#
# Important:
#   • URL-encode special characters in the password
#     (@ -> %40, # -> %23, : -> %3A, / -> %2F, etc.)
#   • Include the <database-name> segment before the "?" (e.g. b2b_workspace)
#   • Allow-list your current IP under Atlas > Network Access
# ---------------------------------------------------------------------------
MONGO_URI=

# ---------------------------------------------------------------------------
# JWT signing secret. Not used until Phase 1 (authentication), but declared
# here so no env changes are needed then. Use a long, random value.
# ---------------------------------------------------------------------------
JWT_SECRET=
