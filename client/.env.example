# ---------------------------------------------------------------------------
# Client environment variables
# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust the values for your environment:
#
#   cp .env.example .env
#
# NOTE: Only variables prefixed with `VITE_` are exposed to the browser bundle.
# Never put secrets here — everything in a Vite client build is public.
# ---------------------------------------------------------------------------

# Base URL of the backend API (no trailing slash).
VITE_API_URL=http://localhost:5000
